# =============================================================================
# x402-1CS Swap Service — Environment Configuration
# =============================================================================
# This service is a swap-as-resource gateway: the buyer supplies the destination
# chain, asset, recipient, and (optionally) refund address per-request as query
# parameters on GET /api/swap. There are no MERCHANT_* variables — every
# settlement routes funds to a buyer-supplied address.
#
# See:
#   - docs/USER_GUIDE.md for the buyer flow
#   - docs/OPERATOR_GUIDE.md for the operator considerations (regulation,
#     KYC/sanctions, refund flow, margin guidance)
# =============================================================================

# --- 1Click Swap API ---
# JWT token for authenticating with the 1CS API
# Request one at: https://docs.near-intents.org
ONE_CLICK_JWT=your-jwt-token-here
# Base URL for the 1CS API (default: https://1click.chaindefuser.com)
ONE_CLICK_BASE_URL=https://1click.chaindefuser.com

# --- Origin Chain (where the buyer pays from) ---
# CAIP-2 network identifier (e.g., eip155:8453 for Base, eip155:42161 for Arbitrum)
ORIGIN_NETWORK=eip155:8453
# 1CS asset ID for the origin asset (e.g., nep141:base-0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913.omft.near)
ORIGIN_ASSET_IN=nep141:base-0x833589fcd6edb6e08f4c7c32d4f71b54bda02913.omft.near
# ERC-20 token contract address on the origin chain
ORIGIN_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Comma-separated list of RPC URLs for the origin chain (first = primary, rest = fallback)
ORIGIN_RPC_URLS=https://mainnet.base.org,https://base.drpc.org

# --- Gateway Operations ---
# WARNING: Both values below are placeholders and WILL FAIL Zod validation at startup.
# Replace them before running the server:
#   FACILITATOR_PRIVATE_KEY — 0x + 64 hex chars (an EVM private key with ETH on the origin chain for gas)
#   GATEWAY_REFUND_ADDRESS — 0x + 40 hex chars (fallback refund destination if the buyer
#                            omits `refundAddress` from the request; buyer's per-request
#                            value always wins when supplied)
# See docs/Facilitator_keys_guidance.md before using a real key.
FACILITATOR_PRIVATE_KEY=0x_replace_with_real_64_hex_char_private_key
GATEWAY_REFUND_ADDRESS=0x_replace_with_real_40_hex_char_address

# --- Operator Margin ---
# Operator margin in basis points, added to the 1CS-quoted `amountIn`.
# 30 = 0.3%. Range: 0 to 1000 (0% to 10%). 0 is allowed for free / loss-leader
# deployments. Surfaced transparently in `extra.crossChain.operatorFee` on
# every 402 envelope.
OPERATOR_MARGIN_BPS=30

# --- Tuning (all optional, defaults shown) ---
# Maximum time to poll 1CS for swap completion (ms)
MAX_POLL_TIME_MS=300000
# Initial polling interval (ms)
POLL_INTERVAL_BASE_MS=2000
# Maximum polling interval after backoff (ms)
POLL_INTERVAL_MAX_MS=30000
# Minimum remaining time on a quote before rejecting (seconds)
QUOTE_EXPIRY_BUFFER_SEC=30

# --- Rate Limiting & Abuse Prevention (all optional, defaults shown) ---
# Maximum 402 (quote) requests per IP within the rate-limit window
RATE_LIMIT_QUOTES_PER_WINDOW=20
# Rate-limit sliding window duration (ms)
RATE_LIMIT_WINDOW_MS=60000
# Maximum number of concurrent in-flight settlements
MAX_CONCURRENT_SETTLEMENTS=10
# How often (ms) the background job prunes expired quote states (0 = disabled)
QUOTE_GC_INTERVAL_MS=60000
# Grace period (ms) past a quote's deadline before it's garbage-collected
QUOTE_GC_GRACE_PERIOD_MS=300000

# --- Token Metadata (for x402 extra fields, defaults shown) ---
# Token name used in EIP-712 domain (must match on-chain token name)
# IMPORTANT: For USDC on Base, the on-chain EIP-712 name is "USD Coin", NOT "USDC"
TOKEN_NAME=USD Coin
# Token version used in EIP-712 domain (must match on-chain token version)
TOKEN_VERSION=2
# Whether the token supports EIP-3009 transferWithAuthorization
TOKEN_SUPPORTS_EIP3009=true

# --- CORS (optional) ---
# Comma-separated origins allowed to call the gateway
# (e.g., "https://buyer.example.com,https://app.example.com").
# Leave unset to reflect any origin (equivalent to `*` but works with credentials).
# Required when a browser-based x402 client needs to read PAYMENT-REQUIRED / PAYMENT-RESPONSE.
ALLOWED_ORIGINS=

# --- Discovery (x402scan / .well-known / OpenAPI, optional) ---
# Full public URL of the gateway — used to emit absolute resource URLs in
# /openapi.json and /.well-known/x402. Required before registering with x402scan.
# Example: https://gateway.example.com  (no trailing slash, no path, no query)
PUBLIC_BASE_URL=
# Comma-separated list of EIP-191 ownership proofs — signatures over the
# canonical message:   x402 ownership of <normalized PUBLIC_BASE_URL>
# Generate with: `npx tsx scripts/generate-ownership-proof.ts`
# Each entry is 0x + 130 hex chars; malformed entries are logged as warnings
# at startup and omitted from the published discovery documents.
OWNERSHIP_PROOFS=
