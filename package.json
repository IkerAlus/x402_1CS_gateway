{
  "name": "x402-1cs-gateway",
  "version": "0.1.0",
  "description": "x402-compliant payment gateway for NEAR Intents 1Click Swap API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.ts",
    "test": "vitest run",
    "test:live": "vitest run src/live-1cs.test.ts",
    "test:watch": "vitest",
    "verify-key": "tsx scripts/verify-api-key.ts",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@defuse-protocol/one-click-sdk-typescript": "^0.1.17",
    "@x402/core": "^2.8.0",
    "@x402/evm": "^2.8.0",
    "cors": "^2.8.6",
    "ethers": "^6.13.0",
    "express": "^4.21.0",
    "helmet": "^8.1.0",
    "sql.js": "^1.14.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "msw": "^2.6.0",
    "prettier": "^3.3.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.60.1"
  }
}
