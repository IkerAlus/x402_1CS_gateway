# ══════════════════════════════════════════════════════════════════════
# x402-1CS Swap Service — Pre-filled config example
# ──────────────────────────────────────────────────────────────────────
# Use case: a public swap-as-resource gateway. Buyer GETs /api/swap with
# query parameters specifying their destination; gateway quotes 1CS,
# returns 402 with a deposit address, buyer signs EIP-3009, gateway
# routes USDC on Base → 1CS → buyer's chosen destination chain/asset/
# recipient. Operator earns OPERATOR_MARGIN_BPS on top of the 1CS quote.
#
# Copy to `.env` (or pass via env-cmd) and fill the three TODO fields.
# ══════════════════════════════════════════════════════════════════════

# ── 1Click Swap API (required) ────────────────────────────────────────
# TODO: paste your 1CS JWT. Generate via the NEAR Intents dashboard.
ONE_CLICK_JWT=REPLACE_ME_WITH_1CS_JWT
ONE_CLICK_BASE_URL=https://1click.chaindefuser.com

# ── Buyer origin: USDC on Base mainnet ────────────────────────────────
# This is the only chain/asset the buyer pays in. Multi-origin support
# is on the roadmap; for now, a single origin per deploy.
ORIGIN_NETWORK=eip155:8453
ORIGIN_ASSET_IN=nep141:base-0x833589fcd6edb6e08f4c7c32d4f71b54bda02913.omft.near
ORIGIN_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
ORIGIN_RPC_URLS=https://mainnet.base.org,https://base.drpc.org

# ── Facilitator wallet (pays gas on Base) ─────────────────────────────
# TODO: paste the private key of a funded Base wallet (~0.002 ETH is plenty).
FACILITATOR_PRIVATE_KEY=REPLACE_ME_WITH_0x_PRIVATE_KEY
# Fallback refund target on Base. Used only when the buyer omits
# `refundAddress` from their request. When the buyer supplies a refund
# address (recommended), 1CS sends refunds straight to them on a failed
# swap and this address is unused.
GATEWAY_REFUND_ADDRESS=0xREPLACE_ME_WITH_REFUND_ADDRESS_ON_BASE

# ── Operator margin (basis points) ────────────────────────────────────
# Added on top of the 1CS-quoted amountIn. Surfaced in extra.crossChain.operatorFee.
# 30 = 0.3%. 0 is allowed (free service). Max 1000 (10%).
OPERATOR_MARGIN_BPS=30

# ── Buyer-supplied destination (for reference, not config) ────────────
# The buyer supplies these per-request as query parameters to GET /api/swap:
#
#   /api/swap?
#     destinationChain=stellar
#     &destinationAsset=nep141:stellar-GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN.omft.near
#     &destinationAddress=GAXYZ...buyer-stellar-account
#     &amountIn=10000000
#     &refundAddress=0xBuyerEvmAddress    # optional
#
# All fields except refundAddress are required. amountIn is in the smallest
# unit of the origin asset (USDC on Base = 6 decimals; 10000000 = 10 USDC).

# ── Tuning (safe defaults) ────────────────────────────────────────────
MAX_POLL_TIME_MS=300000
POLL_INTERVAL_BASE_MS=2000
POLL_INTERVAL_MAX_MS=30000
QUOTE_EXPIRY_BUFFER_SEC=30
RATE_LIMIT_QUOTES_PER_WINDOW=20
RATE_LIMIT_WINDOW_MS=60000
MAX_CONCURRENT_SETTLEMENTS=10
QUOTE_GC_INTERVAL_MS=60000
QUOTE_GC_GRACE_PERIOD_MS=300000

# ── Token metadata (Base USDC EIP-3009 signing domain) ────────────────
TOKEN_NAME=USD Coin
TOKEN_VERSION=2
TOKEN_SUPPORTS_EIP3009=true

# ── CORS (optional) ───────────────────────────────────────────────────
# Comma-separated origins allowed to call the gateway
# (e.g., "https://buyer.example.com,https://app.example.com").
# Leave unset to reflect any origin (equivalent to `*` but works with credentials).
# Required when a browser-based x402 client needs to read PAYMENT-REQUIRED / PAYMENT-RESPONSE.
ALLOWED_ORIGINS=
